<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.ColorPicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TitledPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="600.0" prefWidth="750.0" spacing="8.0" stylesheets="@application.css" xmlns="http://javafx.com/javafx/null" xmlns:fx="http://javafx.com/fxml/1" fx:controller="phillockett65.CardCreate.ColourController">
   <children>
      <TitledPane animated="false" collapsible="false" text="Select Standard Index, Pip and Court Colours">
         <content>
            <GridPane>
              <columnConstraints>
                <ColumnConstraints halignment="RIGHT" hgrow="SOMETIMES" minWidth="10.0" />
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" />
                  <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" />
                  <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                  <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                  <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                  <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
              </columnConstraints>
              <rowConstraints>
                  <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                  <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
              </rowConstraints>
               <children>
                  <Label text="Indices" GridPane.columnIndex="1" GridPane.halignment="CENTER" />
                  <Label text="Pips" GridPane.columnIndex="2" GridPane.halignment="CENTER" />
                  <Label text="Courts" GridPane.columnIndex="4" GridPane.halignment="CENTER" />
                  <Label text="Courts" GridPane.columnIndex="6" GridPane.halignment="CENTER" />
                  <Label fx:id="spadeIndexLabel" text="Spades: " GridPane.rowIndex="1" />
                  <Label fx:id="diamondIndexLabel" text="Diamonds: " GridPane.rowIndex="2" />
                  <Label fx:id="clubIndexLabel" text="Clubs: " GridPane.rowIndex="3" />
                  <Label fx:id="heartIndexLabel" text="Hearts: " GridPane.rowIndex="4" />
                  <ColorPicker fx:id="spadeIndexColourPicker" onAction="#spadeIndexColourPickerActionPerformed" prefWidth="110.0" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                  <ColorPicker fx:id="diamondIndexColourPicker" onAction="#diamondIndexColourPickerActionPerformed" prefWidth="110.0" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                  <ColorPicker fx:id="clubIndexColourPicker" onAction="#clubIndexColourPickerActionPerformed" prefWidth="110.0" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                  <ColorPicker fx:id="heartIndexColourPicker" onAction="#heartIndexColourPickerActionPerformed" prefWidth="110.0" GridPane.columnIndex="1" GridPane.rowIndex="4" />
                  <ColorPicker fx:id="spadePipColourPicker" onAction="#spadePipColourPickerActionPerformed" prefWidth="110.0" GridPane.columnIndex="2" GridPane.rowIndex="1" />
                  <ColorPicker fx:id="diamondPipColourPicker" onAction="#diamondPipColourPickerActionPerformed" prefWidth="110.0" GridPane.columnIndex="2" GridPane.rowIndex="2" />
                  <ColorPicker fx:id="clubPipColourPicker" onAction="#clubPipColourPickerActionPerformed" prefWidth="110.0" GridPane.columnIndex="2" GridPane.rowIndex="3" />
                  <ColorPicker fx:id="heartPipColourPicker" onAction="#heartPipColourPickerActionPerformed" prefWidth="110.0" GridPane.columnIndex="2" GridPane.rowIndex="4" />
                  <Label text="White: " GridPane.columnIndex="3" GridPane.halignment="RIGHT" GridPane.rowIndex="1" />
                  <Label text="Steel: " GridPane.columnIndex="3" GridPane.halignment="RIGHT" GridPane.rowIndex="2" />
                  <Label text="Hair: " GridPane.columnIndex="3" GridPane.halignment="RIGHT" GridPane.rowIndex="3" />
                  <Label text="Flesh: " GridPane.columnIndex="3" GridPane.halignment="RIGHT" GridPane.rowIndex="4" />
                  <ColorPicker fx:id="whiteColourPicker" onAction="#whiteColourPickerActionPerformed" prefWidth="110.0" GridPane.columnIndex="4" GridPane.rowIndex="1" />
                  <ColorPicker fx:id="steelColourPicker" onAction="#steelColourPickerActionPerformed" prefWidth="110.0" GridPane.columnIndex="4" GridPane.rowIndex="2" />
                  <ColorPicker fx:id="hairColourPicker" onAction="#hairColourPickerActionPerformed" prefWidth="110.0" GridPane.columnIndex="4" GridPane.rowIndex="3" />
                  <ColorPicker fx:id="fleshColourPicker" onAction="#fleshColourPickerActionPerformed" prefWidth="110.0" GridPane.columnIndex="4" GridPane.rowIndex="4" />
                  <Label text="Yellow: " GridPane.columnIndex="5" GridPane.halignment="RIGHT" GridPane.rowIndex="1" />
                  <Label text="Red: " GridPane.columnIndex="5" GridPane.halignment="RIGHT" GridPane.rowIndex="2" />
                  <Label text="Blue: " GridPane.columnIndex="5" GridPane.halignment="RIGHT" GridPane.rowIndex="3" />
                  <Label text="Black: " GridPane.columnIndex="5" GridPane.halignment="RIGHT" GridPane.rowIndex="4" />
                  <ColorPicker fx:id="yellowColourPicker" onAction="#yellowColourPickerActionPerformed" prefWidth="110.0" GridPane.columnIndex="6" GridPane.rowIndex="1" />
                  <ColorPicker fx:id="redColourPicker" onAction="#redColourPickerActionPerformed" prefWidth="110.0" GridPane.columnIndex="6" GridPane.rowIndex="2" />
                  <ColorPicker fx:id="blueColourPicker" onAction="#blueColourPickerActionPerformed" prefWidth="110.0" GridPane.columnIndex="6" GridPane.rowIndex="3" />
                  <ColorPicker fx:id="blackColourPicker" onAction="#blackColourPickerActionPerformed" prefWidth="110.0" GridPane.columnIndex="6" GridPane.rowIndex="4" />
               </children>
            </GridPane>
         </content>
      </TitledPane>
   </children>
   <padding>
      <Insets bottom="4.0" left="4.0" right="4.0" top="4.0" />
   </padding>
</VBox>
